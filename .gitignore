# Ignore the API key file to prevent leaks
api_key.json

# Ignore Node.js dependencies (if using Node.js)
node_modules/
npm-debug.log
yarn-error.log

# Ignore logs and temporary files
*.log
logs/
debug.log
error.log
*.cache

# Ignore macOS system files
.DS_Store

# Ignore VS Code settings
.vscode/
*.code-workspace

# Ignore Python cache files (if using Python for backend)
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore build and deployment artifacts
dist/
build/
.env

# Ignore IDE config files (for JetBrains, VS Code, etc.)
.idea/
*.iml

# Ignore GitGuardian’s secret detection cache (if using locally)
.gitguardian/
.gitguardian_ignore
.gitguardian.yaml

# Ignore temporary files
tmp/
temp/
*.swp

# Jekyll build artifacts
_site/
.jekyll-cache/
.sass-cache/
.bundle/
vendor/

# Prevent accidental commits of unrelated scripts and data files
*.py
*.json
_drafts/

# Internal notes / audit docs — keep them local only.
# README.md is fine; the rule blocks ALL_CAPS_NAMES.md at the repo root.
/[A-Z][A-Z_]*.md
!/README.md
_archive/
